# Backend production context — the frontend has its own Dockerfile-specific ignore.
*
!.dockerignore
!package.json
!package-lock.json
!tsconfig.base.json

!docker/
docker/*
!docker/backend/
!docker/backend/Dockerfile

!packages/
packages/*
!packages/engine/
packages/engine/*
!packages/engine/package.json
!packages/engine/tsconfig.json
!packages/engine/src/
!packages/engine/src/**

!packages/backend/
packages/backend/*
!packages/backend/package.json
!packages/backend/prisma.config.ts
!packages/backend/tsconfig.json
!packages/backend/src/
!packages/backend/src/**
!packages/backend/prisma/
!packages/backend/prisma/**

!packages/frontend/
packages/frontend/*
!packages/frontend/package.json

!infra/
infra/*
!infra/package.json
