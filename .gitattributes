# Force LF line endings for all text files (cross-platform consistency)
* text=auto eol=lf

# Explicitly mark file types
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.prisma text eol=lf
*.env* text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Binary files — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
