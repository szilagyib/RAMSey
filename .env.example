# Database
DATABASE_URL=postgresql://ramsey:ramsey@localhost:5432/ramsey

# Redis
REDIS_URL=redis://localhost:6379

# Session signing
JWT_SECRET=change-me-to-a-random-32-char-secret-in-production

# Browser origins
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000
TRUST_PROXY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI (optional)
ANTHROPIC_API_KEY=

# Email (Resend SMTP in production)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Frontend build
# Leave empty locally: Vite proxies API and WebSocket traffic.
VITE_API_ORIGIN=
VITE_WS_ORIGIN=

# Sentry (optional)
SENTRY_DSN=
VITE_SENTRY_DSN=
