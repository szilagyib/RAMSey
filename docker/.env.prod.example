# Production secrets for docker-compose.prod.yml.
# Copy to docker/.env.prod, fill in real values, and keep it out of git.
#
#   cp docker/.env.prod.example docker/.env.prod
#   docker compose --env-file docker/.env.prod \
#     -f docker/docker-compose.yml -f docker/docker-compose.prod.yml up -d

# PostgreSQL password (used for both the postgres container and DATABASE_URL).
POSTGRES_PASSWORD=

# JWT signing secret. MUST be at least 32 characters; generate a random one:
#   openssl rand -base64 48
JWT_SECRET=

# Public origin of the frontend, used for CORS and OAuth/login redirects.
CORS_ORIGIN=https://ramsey.example.com
FRONTEND_URL=https://ramsey.example.com
